# ============================================
# PLATAFORMA DE ATENCIÓN DE EMERGENCIAS - CONFIGURACIÓN
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials

# ============================================
# APPLICATION
# ============================================
APP_NAME=Plataforma de Atención de Emergencias API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ============================================
# CORS (comma separated)
# ============================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# ============================================
# SECURITY - MUST BE CHANGED IN PRODUCTION
# ============================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_with_a_secure_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=15

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Local development: postgresql+psycopg://postgres:postgres@localhost:5432/emergency_db
# Neon Cloud: postgresql+psycopg://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/emergency_db

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FRONTEND_URL=http://localhost:5173

# ============================================
# CLOUDFLARE R2 (Optional - for file storage)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# ============================================
# FIREBASE CLOUD MESSAGING (Optional - push notifications)
# ============================================
# Enable/disable FCM
FCM_ENABLED=false

# Firebase credentials - one of:
# Option 1: JSON string with full credentials (for production/docker)
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", "project_id": "your-project", ...}
# Option 2: Path to serviceAccountKey.json file (for development)
# FIREBASE_CREDENTIALS_JSON=/path/to/serviceAccountKey.json

# Firebase project details
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Push notification TTL (Time To Live) in seconds
PUSH_DEFAULT_TTL_SECONDS=3600

# ============================================
# AI INTEGRATIONS (Optional)
# ============================================
AI_TEXT_AUDIO_PROVIDER=faster_whisper
AI_TEXT_AUDIO_API_KEY=
AI_TEXT_AUDIO_BASE_URL=

# External AI Image Microservice
AI_IMAGE_SERVICE_URL=http://localhost:8090
AI_IMAGE_SERVICE_API_KEY=

# ============================================
# SPEECH-TO-TEXT (faster-whisper Configuration)
# ============================================
# Model size options: tiny, base, small, medium, large
# tiny: ~39MB, base: ~140MB, small: ~466MB
STT_MODEL_SIZE=base

# Device options: cpu, cuda, mps (Apple Silicon)
STT_DEVICE=cpu

# Compute type: int8, int16, float16, float32
# int8: most efficient, lower quality; float32: highest quality, slowest
STT_COMPUTE_TYPE=int8

# Language code (ISO 639-1), e.g., es=Spanish, en=English
STT_LANGUAGE=es

# Beam size for decoding (1 = faster but less accurate, 5+ = slower but more accurate)
STT_BEAM_SIZE=1

# Voice Activity Detection filter
STT_VAD_FILTER=true

# Audio chunk length in milliseconds
STT_CHUNK_LENGTH_MS=30000

# Maximum audio file size in MB
STT_MAX_FILE_SIZE_MB=50.0

# Timeout for transcription in seconds
STT_TIMEOUT_SECONDS=60

# ============================================
# TEXT CLASSIFICATION Configuration
# ============================================
TEXT_CLASSIFICATION_TIMEOUT_SECONDS=30
TEXT_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.5
